{
  "$schema": "https://v2-8-7.turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        "loader/**",
        "components-build/**",
        ".stencil/**",
        "custom-elements.json"
      ],
      "cache": true
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.spec.ts"],
      "outputs": [],
      "cache": true
    },
    "test:coverage": {
      "dependsOn": ["build"],
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.spec.ts"],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "lint": {
      "outputs": [],
      "cache": true
    },
    "lint:fix": {
      "outputs": [],
      "cache": false
    },
    "format": {
      "outputs": [],
      "cache": false
    },
    "format:check": {
      "outputs": [],
      "cache": true
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "validate:pack:react": {
      "dependsOn": ["@telesign/boreal-web-components#build"],
      "cache": false
    },
    "validate:pack:vue": {
      "dependsOn": ["@telesign/boreal-web-components#build"],
      "cache": false
    },
    "validate:pack:angular": {
      "dependsOn": ["@telesign/boreal-web-components#build"],
      "cache": false
    }
  }
}
