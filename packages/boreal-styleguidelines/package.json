{
  "name": "@telesign/boreal-style-guidelines",
  "version": "0.0.2",
  "description": "Base guidelines for  boreal - Multi-brand design system (Proximus, Masiv, Telesign, BICS)",
  "keywords": [
    "boreal",
    "design",
    "system",
    "design-tokens",
    "css-variables",
    "scss",
    "proximus",
    "masiv",
    "telesign",
    "bics"
  ],
  "repository": {
    "type": "git",
    "url": "https://bitbucket.c11.telesign.com/scm/san/boreal-ds.git"
  },
  "license": "ISC",
  "author": "BorealTeam",
  "type": "module",
  "main": "dist/css/boreal.css",
  "files": [
    "dist/css",
    "dist/scss",
    "dist/stencil",
    "src/tokens"
  ],
  "exports": {
    ".": {
      "default": "./dist/css/boreal.css"
    },
    "./css": "./dist/css/*",
    "./css/global": "./dist/css/global.css",
    "./css/theme-proximus": "./dist/css/theme-proximus.css",
    "./css/theme-masiv": "./dist/css/theme-masiv.css",
    "./css/theme-telesign": "./dist/css/theme-telesign.css",
    "./css/theme-bics": "./dist/css/theme-bics.css",
    "./scss": "./dist/scss/_index.scss",
    "./scss/variables": "./dist/scss/variables/_index.scss",
    "./scss/maps": "./dist/scss/maps/_index.scss",
    "./scss/global": "./dist/scss/global/_index.scss",
    "./scss/helpers": "./src/styles/helpers/_index.scss",
    "./stencil": "./dist/stencil/_index.scss",
    "./tokens/theme/masiv": "./src/tokens/theme/masiv.json",
    "./tokens/theme/bics": "./src/tokens/theme/bics.json",
    "./tokens/theme/proximus": "./src/tokens/theme/proximus.json",
    "./tokens/theme/telesign": "./src/tokens/theme/telesign.json",
    "./tokens/primitives": "./src/tokens/primitives/primitives.json",
    "./tokens/usage/colors-themes": "./src/tokens/usage/colors-themes.json"
  },
  "scripts": {
    "release": "release-it",
    "clean": "rimraf dist",
    "generate": "tsx src/generators/generate.ts",
    "validate": "tsx src/generators/validate.ts",
    "build": "pnpm run clean && pnpm run generate && pnpm run validate",
    "dev": "pnpm run build",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.9",
    "fs-extra": "^11.3.0",
    "rimraf": "^6.0.1",
    "sass-embedded": "^1.85.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  }
}