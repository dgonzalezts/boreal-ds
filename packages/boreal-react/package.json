{
  "name": "@telesign/boreal-react",
  "version": "0.1.0-alpha.0",
  "description": "Wrapper for React BorealDS",
  "keywords": [
    "Boreal",
    "BorealDS",
    "Design",
    "System",
    "React",
    "WebComponents"
  ],
  "repository": {
    "type": "git",
    "url": "https://bitbucket.c11.telesign.com/projects/SAN/repos/boreal-ds/"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./css/*": "./dist/css/*",
    "./scss/*": "./dist/scss/*"
  },
  "scripts": {
    "release": "release-it",
    "test": "echo 'No tests configured'",
    "build": "pnpm run tsc && boreal-copy-styles",
    "tsc": "tsc -p . --outDir ./dist"
  },
  "files": [
    "dist",
    "./lib/*"
  ],
  "devDependencies": {
    "@types/react": "^19.2.7",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@telesign/boreal-web-components": "workspace:*",
    "@stencil/react-output-target": "^1.2.0"
  }
}
