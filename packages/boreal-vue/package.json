{
  "name": "@telesign/boreal-vue",
  "version": "0.0.1",
  "description": "Wrapper for VueJS BorealDS",
  "keywords": [
    "Boreal",
    "BorealDS",
    "Design",
    "System",
    "VueJS",
    "WebComponents"
  ],
  "repository": {
    "type": "git",
    "url": "https://bitbucket.c11.telesign.com/projects/SAN/repos/boreal-ds/"
  },
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./css/*": "./dist/css/*",
    "./scss/*": "./dist/scss/*"
  },
  "scripts": {
    "release": "release-it",
    "test": "echo 'No tests configured'",
    "build": "pnpm run tsc && boreal-copy-styles",
    "tsc": "tsc -p . --outDir ./dist"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^5.9.3",
    "vue": "^3.5.25"
  },
  "dependencies": {
    "@telesign/boreal-web-components": "workspace:*",
    "@stencil/vue-output-target": "^0.13.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
